# Server
NODE_ENV=development
PORT=3000
API_URL=http://localhost:3000

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/shaadibio

# JWT - IMPORTANT: Generate with: openssl rand -base64 32
# REPLACE THESE BEFORE RUNNING - These are invalid placeholders
JWT_SECRET=REPLACE_ME_GENERATE_WITH_OPENSSL_RAND_BASE64_32
JWT_REFRESH_SECRET=REPLACE_ME_GENERATE_WITH_OPENSSL_RAND_BASE64_32
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# CORS
FRONTEND_URL=http://localhost:5173

# AWS S3 (Optional - for file uploads)
# Fill these only if using S3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=
AWS_S3_BUCKET=

# Razorpay (Optional - for payments)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Email (Optional)
EMAIL_FROM=noreply@example.com
SENDGRID_API_KEY=
